# for variable in range(start,stop): by default step value is 1
for i in range(1,10):#prints only upto 9 only i.e, prints upto n-1
    print(i)
for i in range(13):
    print(i)#by default starts from zero
for i in range(1,10,2):#for variable(start,stop,step) inorder to skip the numbers step is used
    print(i)
