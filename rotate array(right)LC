class Solution:
    def rotate(self,arr: List[int], d: int) -> None:
        n=len(arr)
        temp=[0]*n
        d%=n
        for i in range(d):
            temp[i]=arr[n-d+i]
        for i in range(n-d):
            temp[i+d]=arr[i]
        for i in range(n):
            arr[i]=temp[i]
          
        return arr
